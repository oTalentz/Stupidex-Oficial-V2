STUPIDEX_SERVER=1
STUPIDEX_DATA_DIR=./data
STUPIDEX_WORKERS=1
STUPIDEX_THREADS=8
STUPIDEX_TIMEOUT=300
STUPIDEX_LOG_LEVEL=info
STUPIDEX_COOKIE_SECURE=1
STUPIDEX_SECRET=troque-por-uma-chave-longa-e-aleatoria
FRONTEND_URL=https://stupidex.squareweb.app
STUPIDEX_CORS=https://stupidex.squareweb.app

# Shell restrito ao workspace
STUPIDEX_ENABLE_SHELL=1
STUPIDEX_SHELL_REQUIRE_APPROVAL=1
STUPIDEX_SHELL_ALLOW_NETWORK=0
STUPIDEX_SHELL_MAX_TIMEOUT=120
STUPIDEX_SHELL_MAX_OUTPUT_BYTES=65536
STUPIDEX_SHELL_COMMANDS=python,python3,pytest,git,node,npm,npx,pnpm,yarn,cargo,go,dotnet,make,cmake,ruff,mypy,eslint,prettier

# Modelo padrao
STUPIDEX_PROVIDER=openai
STUPIDEX_MODEL=gpt-5.4
STUPIDEX_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
